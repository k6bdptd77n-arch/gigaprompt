def cmd_start(args):
    """Start the agent."""
    if is_agent_running():
        safe_print("[OK] Already running")
        return 0

    if not AGENT_PATH.exists():
        safe_print(f"[X] Agent not found: {AGENT_PATH}")
        safe_print(f"   Run: mem install")
        return 1

    import subprocess
    env = os.environ.copy()
    env["PYTHONUNBUFFERED"] = "1"

    log_path = Path.home() / ".super_memory" / "agent.log"
    pid_file = Path.home() / ".super_memory" / "agent.pid"

    proc = subprocess.Popen(
        [sys.executable, str(AGENT_PATH)],
        env=env,
        stdout=open(log_path, "a"),
        stderr=subprocess.STDOUT,
        start_new_session=True
    )

    pid_file.write_text(str(proc.pid))

    import time
    for i in range(10):
        time.sleep(0.5)
        if is_agent_running():
            safe_print(f"[OK] Started (PID: {proc.pid})")
            return 0

    safe_print("⚠️  Started but not responding yet")
    return 0


def cmd_stop(args):
    """Stop the agent."""
    if not is_agent_running():
        safe_print("Not running")
        return 0

    import subprocess
    import signal

    pid_file = Path.home() / ".super_memory" / "agent.pid"

    # Try PID file first (most reliable)
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, signal.SIGTERM)
            pid_file.unlink(missing_ok=True)
            safe_print("[OK] Stopped")
            return 0
        except (ProcessLookupError, ValueError, OSError):
            pid_file.unlink(missing_ok=True)

    # Fallback: platform-specific port scan
    try:
        if sys.platform == "win32":
            result = subprocess.run(
                ["netstat", "-ano"],
                capture_output=True, text=True
            )
            for line in result.stdout.splitlines():
                if ":8080" in line and "LISTENING" in line:
                    pid = line.strip().split()[-1]
                    subprocess.run(["taskkill", "/PID", pid, "/F"], capture_output=True)
        else:
            result = subprocess.run(
                ["lsof", "-ti", ":8080"],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                for pid in result.stdout.strip().split('\n'):
                    if pid:
                        os.kill(int(pid), signal.SIGTERM)
            else:
                # lsof not available — try ss/netstat
                result = subprocess.run(
                    ["ss", "-tlnp", "sport", "=", ":8080"],
                    capture_output=True, text=True
                )
                import re
                for pid in re.findall(r'pid=(\d+)', result.stdout):
                    os.kill(int(pid), signal.SIGTERM)
        safe_print("[OK] Stopped")
    except (OSError, ValueError, subprocess.SubprocessError) as e:
        safe_print(f"[X] Could not stop agent: {e}")
        return 1

    return 0


def cmd_shell(args):
    """Interactive shell mode."""
    safe_print("=" * 50)
    safe_print("  Super Memory — Interactive Shell")
    safe_print("=" * 50)
    safe_print("  Type 'help' for commands, 'exit' to quit")
    safe_print("=" * 50)

    while True:
        try:
            line = input("\n(mem) ").strip()
        except (EOFError, KeyboardInterrupt):
            safe_print("\n\n[Bye!]")
            break

        if not line:
            continue

        if line in ('exit', 'quit', 'q'):
            safe_print("[Bye!]")
            break

        if line in ('help', '?'):
            safe_print("""
  Commands:
    add <text>           — Add entry
    done <task>         — Mark task completed
    decision <topic>    — Add decision
    blocked <task>      — Add blocker
    search <query>      — Search memories
    recent [n]          — Recent entries
    summary             — Memory summary
    context             — AI context
    tokens              — Token usage
    status              — Agent status

    project_list        — List projects
    project_add <name>  — Add project
    file_list           — List tracked files
    folder_list         — List tracked folders

    agent_list          — List agents
    agent_add <name>    — Add agent
    agent_select <name> — Switch agent
    agent_info [name]   — Agent info

    exit, quit, q       — Exit shell
""")
            continue

        # Parse command
        parts = line.split(None, 1)
        cmd = parts[0] if parts else ''
        arg = parts[1] if len(parts) > 1 else ''

        if cmd == 'add':
            if arg:
                result = api_post("/add", {"text": arg, "source": "shell"})
                if "error" not in result:
                    safe_print(f"[OK] Added")
                else:
                    safe_print(f"[X] Error: {result['error']}")
            else:
                safe_print("[X] Usage: add <text>")

        elif cmd == 'done':
            if arg:
                result = api_post("/add_completed", {"task": arg, "source": "shell"})
                if "error" not in result:
                    safe_print(f"[OK] Completed: {arg}")
                else:
                    safe_print(f"[X] Error: {result['error']}")
            else:
                safe_print("[X] Usage: done <task>")

        elif cmd == 'search':
            if arg:
                from urllib.parse import urlencode
                result = api_get(f"/search?{urlencode({'q': arg})}")
                if "error" not in result:
                    results = result.get("results", [])
                    if not results:
                        safe_print(f"  No results for: {arg}")
                    for r in results[:10]:
                        safe_print(f"  [{r.get('type', '?')}] {r.get('text', '')[:60]}")
                else:
                    safe_print(f"[X] Error: {result['error']}")
            else:
                safe_print("[X] Usage: search <query>")

        elif cmd == 'recent':
            limit = int(arg) if arg.isdigit() else 10
            result = api_get("/recent")
            if "error" not in result:
                memories = result.get("memories", [])
                if not memories:
                    safe_print("  No entries yet")
                for m in memories[:limit]:
                    safe_print(f"  [{m.get('type', '?')}] {m.get('text', '')[:60]}")
            else:
                safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'summary':
            result = api_get("/summary")
            if "error" not in result:
                safe_print(f"""
  Total:     {result.get('total', 0)}
  Completed: {result.get('completed', 0)}
  Decisions: {result.get('decisions', 0)}
  Blockers:  {result.get('blockers', 0)}
""")
            else:
                safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'status':
            result = api_get("/health")
            if "error" not in result:
                safe_print(f"[OK] Super Memory running")
            else:
                safe_print("[X] Agent not running. Start with: start")

        elif cmd == 'start':
            import subprocess
            if is_agent_running():
                safe_print("[OK] Already running")
            else:
                proc = subprocess.Popen([sys.executable, str(AGENT_PATH)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
                import time
                for i in range(10):
                    time.sleep(0.5)
                    if is_agent_running():
                        break
                safe_print("[OK] Started")

        elif cmd == 'project_list':
            result = api_get("/projects/list")
            if "error" not in result:
                projects = result.get('projects', [])
                if not projects:
                    safe_print("  No projects")
                for p in projects:
                    safe_print(f"  - {p.get('name')}")
            else:
                # Try /projects endpoint
                result = api_get("/projects")
                if "error" not in result:
                    projects = result.get('projects', [])
                    if not projects:
                        safe_print("  No projects")
                    for p in projects:
                        safe_print(f"  - {p.get('name')}")
                else:
                    safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'agent_list':
            result = api_get("/agents")
            if "error" not in result:
                agents = result.get('agents', [])
                active = result.get('active', 'default')
                if not agents:
                    safe_print("  No agents configured")
                for a in agents:
                    name = a.get('name', '')
                    marker = " (active)" if name == active else ""
                    safe_print(f"  {name}{marker}")
            else:
                safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'agent_add':
            if not arg:
                safe_print("[X] Usage: agent_add <name>")
            else:
                # Shell doesn't parse flags, so use first word as name
                name = arg.split()[0] if ' ' in arg else arg
                result = api_post("/agents/add", {"name": name, "type": "claude"})
                if "error" not in result:
                    safe_print(f"[OK] Agent added: {name}")
                else:
                    safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'agent_select':
            if not arg:
                safe_print("[X] Usage: agent_select <name>")
            else:
                result = api_post("/agents/select", {"name": arg})
                if "error" not in result:
                    safe_print(f"[OK] Active agent: {arg}")
                else:
                    safe_print(f"[X] Error: {result['error']}")

        elif cmd == 'agent_info':
            name = arg or 'default'
            result = api_get(f"/agents/{name}")
            if "error" not in result:
                a = result.get('agent', {})
                safe_print(f"  Name: {a.get('name')}")
                safe_print(f"  Type: {a.get('agent_type', 'N/A')}")
                safe_print(f"  Model: {a.get('model', 'N/A')}")
            else:
                safe_print(f"[X] Error: {result.get('error', 'Unknown')}")

        elif cmd == 'agent_delete':
            if not arg:
                safe_print("[X] Usage: agent_delete <name>")
            elif arg == 'default':
                safe_print("[X] Cannot delete 'default' agent")
            else:
                result = api_post("/agents/delete", {"name": arg})
                if "error" not in result:
                    safe_print(f"[OK] Agent deleted: {arg}")
                else:
                    safe_print(f"[X] Error: {result['error']}")

        else:
            safe_print(f"[X] Unknown command: {cmd}")
            safe_print("  Type 'help' for available commands")


def cmd_install(args):
    """Install agent and enable auto-start."""
    safe_print("🔧 Installing Super Memory...")
    
    super_mem_dir = Path.home() / ".super_memory"
    super_mem_dir.mkdir(exist_ok=True)
    
    import shutil
    source = Path(__file__).parent
    
    if source.resolve() != super_mem_dir.resolve():
        files_to_copy = ["memory_agent.py", "hook.sh", "context_inject.py"]
        for f in files_to_copy:
            src = source / f
            if src.exists():
                shutil.copy(src, super_mem_dir / f)
                safe_print(f"   [OK] {f}")
    
    safe_print("[OK] Installation complete!")
    safe_print("Next steps:")
    safe_print("  1. Restart terminal or source ~/.bashrc")
    safe_print("  2. Run: mem start")
    safe_print("  3. Run: mem add \"First entry\"")

    return 0


