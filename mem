# ANSI colors — auto-disabled when not a TTY
_IS_TTY = sys.stdout.isatty()

def _c(code: str, text: str) -> str:
    if not _IS_TTY:
        return text
    return f"\033[{code}m{text}\033[0m"

def _amber(t):  return _c("33", t)
def _green(t):  return _c("32", t)
def _red(t):    return _c("31", t)
def _cyan(t):   return _c("36", t)
def _bold(t):   return _c("1",  t)
def _dim(t):    return _c("2",  t)
def _purple(t): return _c("35", t)

def _cls():
    if _IS_TTY:
        print("\033[2J\033[H", end="")

def _hr(char="─", width=58):
    safe_print(_dim(char * width))

def _ask(prompt: str, default: str = "") -> str:
    try:
        val = input(prompt).strip()
        return val if val else default
    except (EOFError, KeyboardInterrupt):
        return default

def _pick(prompt: str, options: list) -> str:
    """Show numbered list, return chosen value or empty string."""
    for i, (label, _) in enumerate(options, 1):
        safe_print(f"  {_amber(str(i))}.  {label}")
    choice = _ask(f"\n{prompt} [1-{len(options)}]: ", "")
    try:
        idx = int(choice) - 1
        if 0 <= idx < len(options):
            return options[idx][1]
    except (ValueError, IndexError):
        pass
    return ""


def _header(summary: dict, agent: str, connected: bool):
    _cls()
    status = _green("● Connected") if connected else _red("● Offline")
    total  = summary.get("total", 0)
    done   = summary.get("completed", 0)
    dec    = summary.get("decisions", 0)
    blk    = summary.get("blockers", 0)

    safe_print("")
    safe_print(_bold("  Super Memory") + "  " + status + "  " + _dim(f"agent: {agent}"))
    safe_print(_dim(f"  {total} entries  ·  {done} completed  ·  {dec} decisions  ·  {blk} blockers"))
    safe_print("")


def _ensure_agent_running() -> bool:
    """Start agent if not running. Returns True if running after attempt."""
    if is_agent_running():
        return True

    safe_print(_amber("  Agent not running — starting..."))

    if not AGENT_PATH.exists():
        safe_print(_red(f"  [X] memory_agent.py not found at {AGENT_PATH}"))
        safe_print(_dim("      Run: mem install"))
        return False

    import subprocess, time
    log_path = Path.home() / ".super_memory" / "agent.log"
    pid_file = Path.home() / ".super_memory" / "agent.pid"
    env = os.environ.copy()
    env["PYTHONUNBUFFERED"] = "1"

    proc = subprocess.Popen(
        [sys.executable, str(AGENT_PATH)],
        env=env,
        stdout=open(log_path, "a"),
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    pid_file.write_text(str(proc.pid))

    for _ in range(12):
        time.sleep(0.4)
        if is_agent_running():
            safe_print(_green(f"  [OK] Started  (PID {proc.pid})"))
            return True

    safe_print(_red("  [X] Agent started but not responding — check agent.log"))
    return False


