# ============================================================
# MAIN
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        description='Super Memory CLI — Universal AI Memory',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # Memory commands
    p_add = subparsers.add_parser('add', help='Add entry')
    p_add.add_argument('text', nargs='+', help='Entry text')
    p_add.add_argument('-t', '--type', default='general', help='Entry type')
    
    p_done = subparsers.add_parser('done', help='Mark task completed')
    p_done.add_argument('task', nargs='+', help='Task description')
    
    p_dec = subparsers.add_parser('decision', help='Add decision')
    p_dec.add_argument('topic', nargs='+', help='Decision topic')
    p_dec.add_argument('-d', '--decision', help='Decision text')
    p_dec.add_argument('-r', '--reason', help='Reason')
    
    p_blk = subparsers.add_parser('blocked', help='Add blocker')
    p_blk.add_argument('task', nargs='+', help='Blocked task')
    p_blk.add_argument('-b', '--blocker', help='What is blocking')
    p_blk.add_argument('-n', '--needed', help='What is needed')
    
    p_search = subparsers.add_parser('search', help='Search')
    p_search.add_argument('query', nargs='+', help='Search query')
    
    p_recent = subparsers.add_parser('recent', help='Recent entries')
    p_recent.add_argument('-n', '--limit', type=int, default=10, help='Limit')
    
    subparsers.add_parser('summary', help='Memory summary')
    subparsers.add_parser('context', help='AI context')
    subparsers.add_parser('tokens', help='Token usage summary')
    
    # Agent commands
    subparsers.add_parser('status', help='Check agent status')
    subparsers.add_parser('start', help='Start agent')
    subparsers.add_parser('stop', help='Stop agent')
    subparsers.add_parser('install', help='Install agent')
    
    # File Memory commands (MVP 8)
    p_file_add = subparsers.add_parser('file_add', help='Add/update file info')
    p_file_add.add_argument('filepath', help='File path')
    p_file_add.add_argument('--purpose', '-p', default='', help='Purpose of file')
    p_file_add.add_argument('--description', '-d', default='', help='Description')
    p_file_add.add_argument('--patterns', help='Comma-separated patterns')

    p_file_list = subparsers.add_parser('file_list', help='List tracked files')

    p_file_search = subparsers.add_parser('file_search', help='Search files')
    p_file_search.add_argument('query', nargs='+', help='Search query')

    p_file_info = subparsers.add_parser('file_info', help='Get file info')
    p_file_info.add_argument('filepath', help='File path')

    p_file_context = subparsers.add_parser('file_context', help='Full context for file')
    p_file_context.add_argument('filepath', help='File path')

    p_folder_add = subparsers.add_parser('folder_add', help='Add/update folder info')
    p_folder_add.add_argument('path', help='Folder path')
    p_folder_add.add_argument('--purpose', '-p', default='', help='Purpose')
    p_folder_add.add_argument('--description', '-d', default='', help='Description')
    p_folder_add.add_argument('--blockers', help='Comma-separated blockers')

    p_folder_list = subparsers.add_parser('folder_list', help='List tracked folders')

    p_project_add = subparsers.add_parser('project_add', help='Add/update project')
    p_project_add.add_argument('name', help='Project name')
    p_project_add.add_argument('--root', dest='root_path', default='', help='Root path')
    p_project_add.add_argument('--architecture', '-a', default='', help='Architecture')

    p_project_list = subparsers.add_parser('project_list', help='List projects')

    subparsers.add_parser('help', help='Show help')
    
    args = parser.parse_args()
    
    if not args.command:
        args.command = 'status'
    
    commands = {
        'add': cmd_add,
        'done': cmd_done,
        'decision': cmd_decision,
        'blocked': cmd_blocked,
        'search': cmd_search,
        'recent': cmd_recent,
        'summary': cmd_summary,
        'context': cmd_context,
        'tokens': cmd_tokens,
        'status': cmd_status,
        'start': cmd_start,
        'stop': cmd_stop,
        'install': cmd_install,
        'file_add': cmd_file_add,
        'file_list': cmd_file_list,
        'file_search': cmd_file_search,
        'file_info': cmd_file_info,
        'file_context': cmd_file_context,
        'folder_add': cmd_folder_add,
        'folder_list': cmd_folder_list,
        'project_add': cmd_project_add,
        'project_list': cmd_project_list,
        'help': lambda a: parser.print_help()
    }
    
    cmd = commands.get(args.command)
    if cmd:
        sys.exit(cmd(args) or 0)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == '__main__':
    main()