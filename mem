def cmd_launch(args):
    """Interactive launcher — the main UX entry point."""

    # ── Step 1: ensure agent is running ──────────────────────────
    if not _ensure_agent_running():
        _ask(_dim("\n  [Enter to exit]"))
        return 1

    # ── Step 2: load state ────────────────────────────────────────
    summary = api_get("/summary")
    agent   = summary.get("active_agent", "default") if "error" not in summary else "default"

    # Main loop
    while True:
        _header(summary, agent, connected=True)

        project_r = api_get("/projects")
        projects  = project_r.get("projects", []) if "error" not in project_r else []
        proj_line = _dim(f"  Project: {projects[0]['name']}") if projects else _dim("  No project selected")
        safe_print(proj_line)
        safe_print("")

        _hr()
        safe_print(_bold("  What do you want to do?\n"))

        menu = [
            (_amber("1") + "  Start AI session          " + _dim("→ load context for Claude"),      "ai_session"),
            (_amber("2") + "  Open dashboard            " + _dim("→ browser UI at :8080/dashboard"), "dashboard"),
            (_amber("3") + "  Quick add memory          " + _dim("→ capture a note, task, decision"),"quick_add"),
            (_amber("4") + "  Select / switch project   " + _dim("→ change active project context"), "project"),
            (_amber("5") + "  Select / switch agent     " + _dim("→ change AI agent"),              "agent"),
            (_amber("6") + "  Today's summary           " + _dim("→ what was done, costs"),         "summary"),
            (_amber("7") + "  Search memories & files   " + _dim("→ find anything"),                "search"),
            (_amber("8") + "  Generate CLAUDE.md        " + _dim("→ wire Claude Code to memory"),   "claude_md"),
            (_amber("0") + "  Exit",                                                                  "exit"),
        ]

        for label, _ in menu:
            safe_print(f"    {label}")

        safe_print("")
        _hr()
        choice = _ask(_amber("  → ")).strip()

        action_map = {str(i): v for i, (_, v) in enumerate(menu)}
        action = action_map.get(choice, "")

        if action == "exit" or choice in ("q", "quit", "exit"):
            safe_print(_dim("\n  Goodbye.\n"))
            break
        elif action == "ai_session":
            _menu_ai_session(summary, agent)
        elif action == "dashboard":
            cmd_monitor(args)
            import time; time.sleep(1)
        elif action == "quick_add":
            _menu_quick_add()
        elif action == "project":
            chosen = _menu_select_project()
            # Switch agent context to match project if agent exists
            if chosen:
                agent_r = api_get("/agents")
                agent_names = [a['name'] for a in agent_r.get("agents", [])]
                if chosen in agent_names:
                    api_post("/agents/select", {"name": chosen})
                    agent = chosen
        elif action == "agent":
            new_agent = _menu_select_agent()
            if new_agent:
                agent = new_agent
        elif action == "summary":
            _menu_today_summary()
        elif action == "search":
            _menu_search()
        elif action == "claude_md":
            _menu_generate_claude_md()
        else:
            import time; time.sleep(0.1)

        # Refresh summary after any action
        summary = api_get("/summary")
        agent   = summary.get("active_agent", "default") if "error" not in summary else agent

    return 0


