    # Build prompt from args
    if args.file:
        try:
            prompt = open(args.file, encoding="utf-8").read()
        except OSError as e:
            safe_print(f"[X] Cannot read file: {e}")
            return 1
    elif args.stdin or not sys.stdin.isatty():
        prompt = sys.stdin.read()
    elif args.prompt:
        prompt = args.prompt
    else:
        # Just print context
        safe_print(context or "No context available")
        return 0

    parts = []
    if args.prefix:
        parts.append(args.prefix)
    if context:
        parts.append(context)
    parts.append(prompt)
    if args.suffix:
        parts.append(args.suffix)

    if args.summary:
        s = api_get("/summary")
        if "error" not in s:
            parts.append(
                f"\n## Memory Summary\n"
                f"Total: {s.get('total', 0)} | "
                f"Completed: {s.get('completed', 0)} | "
                f"Decisions: {s.get('decisions', 0)} | "
                f"Blockers: {s.get('blockers', 0)}"
            )

    safe_print("\n".join(parts))
    return 0


def cmd_monitor(args):
    """Open the dashboard in the browser.

    The dashboard is served directly by memory_agent.py at /dashboard —
    no extra process needed. Just ensure the agent is running.
    """
    import webbrowser

    api_url = API_HOST.rstrip('/')
    dashboard_url = f"{api_url}/dashboard"

    if not is_agent_running():
        safe_print("[X] Super Memory is not running.")
        safe_print("    Start with: mem start")
        return 1

    safe_print(f"[OK] Opening dashboard: {dashboard_url}")
    webbrowser.open(dashboard_url)
    return 0


def cmd_daemon(args):
    """Manage the daemon (install/start/stop/status) via launcher.py."""
    launcher_path = Path(__file__).parent / "daemon" / "launcher.py"
    if not launcher_path.exists():
        launcher_path = Path.home() / ".super_memory" / "daemon" / "launcher.py"

    action = args.action or "status"

    if not launcher_path.exists():
        # Fallback: handle basic actions inline
        if action == "status":
            return cmd_status(args)
        elif action == "start":
            return cmd_start(args)
        elif action == "stop":
            return cmd_stop(args)
        else:
            safe_print("[X] daemon/launcher.py not found.")
            return 1

    import subprocess
    result = subprocess.run(
        [sys.executable, str(launcher_path), action],
        check=False
    )
    return result.returncode


