def cmd_file_add(args):
    """Add or update file info."""
    filepath = args.filepath
    purpose = args.purpose or ""
    description = args.description or ""
    patterns = args.patterns.split(',') if args.patterns else []
    
    result = api_post("/files/add", {
        "filepath": filepath,
        "purpose": purpose,
        "description": description,
        "patterns": patterns,
        "decisions": []
    })
    
    if "error" in result:
        safe_print(f"[X] Error: {result['error']}")
        return 1
    
    safe_print(f"[OK] File added: {filepath}")
    return 0


def cmd_file_list(args):
    """List all tracked files."""
    result = api_get("/files/list")
    
    if "error" in result:
        safe_print(f"[X] Error: {result['error']}")
        return 1
    
    files = result.get('files', [])
    if not files:
        safe_print("No files tracked yet")
        safe_print("   Run: mem file_add /path/to/file.py --purpose \"What this does\"")
        return 0
    
    safe_print(f"[F] Tracked files: {len(files)}")
    for f in files[:20]:
        ext = f.get('extension', '')
        purpose = f.get('purpose', '')[:50]
        safe_print(f"  [{ext}] {f.get('filepath', '')}")
        if purpose:
            safe_print(f"         → {purpose}")
    
    if len(files) > 20:
        safe_print(f"  ... and {len(files) - 20} more")
    
    return 0


def cmd_file_search(args):
    """Search tracked files."""
    query = ' '.join(args.query) if args.query else ""
    if not query:
        safe_print("[X] Error: query required")
        safe_print("   Usage: mem file_search auth")
        return 1
    
    result = api_get(f"/files/search?q={query}")
    
    if "error" in result:
        safe_print(f"[X] Error: {result['error']}")
        return 1
    
    files = result.get('results', [])
    if not files:
        safe_print(f"No files found for: {query}")
        return 0
    
    safe_print(f"Found {len(files)} files for '{query}':")
    for f in files:
        safe_print(f"  {f.get('filepath', '')}")
        if f.get('purpose'):
            safe_print(f"    → {f.get('purpose', '')[:60]}")
    
    return 0


def cmd_file_info(args):
    """Get info about a file."""
    filepath = args.filepath
