    """Add decision."""
    topic = ' '.join(args.topic) if args.topic else ""
    decision = args.decision or topic
    reason = args.reason or ""
    
    if not topic:
        print("❌ Error: topic required")
        print("   Usage: mem decision \"Use Postgres\" --reason \"Better performance\"")
        return 1
    
    result = api_post("/add_decision", {
        "topic": topic,
        "decision": decision,
        "reason": reason,
        "source": "cli"
    })
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print(f"⚖️ Decision added: {topic[:50]}...")
    return 0


def cmd_blocked(args):
    """Add blocker."""
    task = ' '.join(args.task) if args.task else ""
    blocker = args.blocker or "unknown"
    needed = args.needed or "TBD"
    
    if not task:
        print("❌ Error: task required")
        print("   Usage: mem blocked \"API integration\" --blocker \"Waiting for spec\"")
        return 1
    
    result = api_post("/add_blocker", {
        "task": task,
        "blocker": blocker,
        "needed": needed,
        "source": "cli"
    })
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print(f"🚧 Blocker added: {task[:50]}...")
    return 0


def cmd_search(args):
    """Search memories."""
    query = ' '.join(args.query) if args.query else ""
    if not query:
        print("❌ Error: query required")
        print("   Usage: mem search \"auth\"")
        return 1
    
    result = api_get(f"/search?q={query}")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    results = result.get("results", [])
    
    if not results:
        print(f"No results for: {query}")
        return 0
    
    print(f"Found {len(results)} results:\n")
    for r in results[:10]:
        print(f"[{r.get('type', '?')}] {r.get('text', '')[:80]}")
        print()
    
    return 0


def cmd_recent(args):
    """Show recent entries."""
    result = api_get("/recent")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    memories = result.get("memories", [])
    
    if not memories:
        print("No entries yet")
        return 0
    
    limit = args.limit or 10
    for m in memories[:limit]:
        print(f"[{m.get('type', '?')}] {m.get('text', '')[:80]}")
    
    return 0


def cmd_summary(args):
    """Show memory summary."""
    result = api_get("/summary")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print()
    print("📊 Memory Summary")
    print("=" * 40)
    print(f"  Total:     {result.get('total', 0)}")
    print(f"  Completed: {result.get('completed', 0)}")
    print(f"  Decisions: {result.get('decisions', 0)}")
    print(f"  Blockers:  {result.get('blockers', 0)}")
    print(f"  Learnings: {result.get('learnings', 0)}")
    print()
    
    return 0


def cmd_context(args):
    """Get AI context."""
    result = api_get("/context")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    context = result.get("context", "")
    print(context or "No context available")
    
    return 0


def cmd_tokens(args):
    """Show token usage summary."""
    result = api_get("/tokens/summary")

    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1

    print("📊 Token Usage Summary")
    print("=" * 40)
    print(f"  Total Requests:  {result.get('total_requests', 0)}")
    print(f"  Input Tokens:    {result.get('total_input_tokens', 0):,}")
    print(f"  Output Tokens:   {result.get('total_output_tokens', 0):,}")
    print(f"  Estimated Cost:  ${result.get('total_cost_usd', 0):.4f}")
    print(f"  Cache Savings:    ${result.get('total_cache_savings_usd', 0):.2f}")
    models = result.get("models_used", [])
    if models:
        print(f"  Models:          {', '.join(models)}")
    daily = result.get("daily_costs", {})
    if daily:
        print("\n  Daily Costs:")
        for day, cost in sorted(daily.items()):
            print(f"    {day}: ${cost:.4f}")

    return 0


def cmd_status(args):
    """Check agent status."""
    if is_agent_running():
        print("✅ Super Memory running")
        
        result = api_get("/summary")
        if "error" not in result:
            print(f"   Entries: {result.get('total', '?')}")
    else:
        print("❌ Super Memory not running")
        print(f"   Start: mem start")
        return 1
    
    return 0


def cmd_start(args):
    """Start the agent."""
    if is_agent_running():
        print("✅ Already running")
        return 0
    
    if not AGENT_PATH.exists():
        print(f"❌ Agent not found: {AGENT_PATH}")
        return 1
    
    import subprocess
    env = os.environ.copy()
    env["PYTHONUNBUFFERED"] = "1"
    
    proc = subprocess.Popen(
        [sys.executable, str(AGENT_PATH)],
        env=env,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True
    )
    
    import time
    for i in range(10):
        time.sleep(0.5)
        if is_agent_running():
            print(f"✅ Started (PID: {proc.pid})")
            return 0
    
    print("⚠️  Started but not responding yet")
    return 0


def cmd_stop(args):
    """Stop the agent."""
    if not is_agent_running():
        print("Not running")
        return 0
    
    import subprocess
    try:
        result = subprocess.run(
            ["lsof", "-ti", ":8080"],
            capture_output=True, text=True
        )
        pids = result.stdout.strip().split('\n')
        for pid in pids:
            if pid:
                os.kill(int(pid), 9)
        print("✅ Stopped")
    except:
        print("⚠️  Could not stop")
        return 1
    
    return 0


def cmd_install(args):
    """Install agent and enable auto-start."""
    print("🔧 Installing Super Memory...")
    
    super_mem_dir = Path.home() / ".super_memory"
    super_mem_dir.mkdir(exist_ok=True)
    
    import shutil
    source = Path(__file__).parent
    
    if source.resolve() != super_mem_dir.resolve():
        files_to_copy = ["memory_agent.py", "hook.sh", "context_inject.py"]
        for f in files_to_copy:
            src = source / f
            if src.exists():
                shutil.copy(src, super_mem_dir / f)
                print(f"   ✅ {f}")
    
    print()
    print("✅ Installation complete!")
    print()
    print("Next steps:")
    print("  1. Restart terminal or source ~/.bashrc")
    print("  2. Run: mem start")
    print("  3. Run: mem add \"First entry\"")
    print()
    
    return 0


