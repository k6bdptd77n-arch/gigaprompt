#!/usr/bin/env python3
"""
Super Memory CLI
================
Standalone CLI for Super Memory — works WITHOUT bash hooks.

Usage:
    mem add "text"           Add entry
    mem done "task"         Mark task completed
    mem decision "topic"    Add decision
    mem blocked "task"     Add blocker
    mem search "query"      Search
    mem recent              Recent entries
    mem summary             Memory summary
    mem context              AI context
    mem status              Check agent
    mem start               Start agent
    mem stop                Stop agent
    mem file_add            Add file to tracking
    mem file_list           List tracked files
    mem folder_add          Add folder to tracking
    mem help                Show help
"""

import sys
import os
import json
import argparse
from pathlib import Path

# Config
API_HOST = os.environ.get('SUPER_MEMORY_API', 'http://127.0.0.1:8080')
AGENT_PATH = Path.home() / ".super_memory" / "memory_agent.py"


def api_get(endpoint: str) -> dict:
    """GET request to memory API."""
    import urllib.request
    import urllib.error
    
    url = f"{API_HOST}{endpoint}"
    try:
        with urllib.request.urlopen(url, timeout=5) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.URLError as e:
        return {"error": str(e)}


def api_post(endpoint: str, data: dict) -> dict:
    """POST request to memory API."""
    import urllib.request
    import urllib.error
    
    url = f"{API_HOST}{endpoint}"
    payload = json.dumps(data).encode()
    
    req = urllib.request.Request(
        url,
        data=payload,
        headers={'Content-Type': 'application/json'}
    )
    
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.URLError as e:
        return {"error": str(e)}


def is_agent_running() -> bool:
    """Check if agent is running."""
    result = api_get("/health")
    return "error" not in result


# ============================================================
# MEMORY COMMANDS
# ============================================================

def cmd_add(args):
    """Add entry."""
    text = ' '.join(args.text) if args.text else ""
    if not text:
        print("❌ Error: text required")
        print("   Usage: mem add \"some text\"")
        return 1
    
    result = api_post("/add", {
        "text": text,
        "type": args.type or "general",
        "source": "cli"
    })
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print(f"✅ Added: {text[:50]}...")
    return 0


def cmd_done(args):
    """Mark task completed."""
    task = ' '.join(args.task) if args.task else ""
    if not task:
        print("❌ Error: task required")
        print("   Usage: mem done \"implemented auth\"")
        return 1
    
    result = api_post("/add_completed", {
        "task": task,
        "source": "cli"
    })
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print(f"✅ Completed: {task[:50]}...")
    return 0


