def cmd_file_add(args):
    """Add or update file info."""
    filepath = args.filepath
    purpose = args.purpose or ""
    description = args.description or ""
    patterns = args.patterns.split(',') if args.patterns else []
    
    result = api_post("/files/add", {
        "filepath": filepath,
        "purpose": purpose,
        "description": description,
        "patterns": patterns,
        "decisions": []
    })
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    print(f"✅ File added: {filepath}")
    return 0


def cmd_file_list(args):
    """List all tracked files."""
    result = api_get("/files/list")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    files = result.get('files', [])
    if not files:
        print("No files tracked yet")
        print("   Run: mem file_add /path/to/file.py --purpose \"What this does\"")
        return 0
    
    print(f"📁 Tracked files: {len(files)}")
    for f in files[:20]:
        ext = f.get('extension', '')
        purpose = f.get('purpose', '')[:50]
        print(f"  [{ext}] {f.get('filepath', '')}")
        if purpose:
            print(f"         → {purpose}")
    
    if len(files) > 20:
        print(f"  ... and {len(files) - 20} more")
    
    return 0


def cmd_file_search(args):
    """Search tracked files."""
    query = ' '.join(args.query) if args.query else ""
    if not query:
        print("❌ Error: query required")
        print("   Usage: mem file_search auth")
        return 1
    
    result = api_get(f"/files/search?q={query}")
    
    if "error" in result:
        print(f"❌ Error: {result['error']}")
        return 1
    
    files = result.get('results', [])
    if not files:
        print(f"No files found for: {query}")
        return 0
    
    print(f"Found {len(files)} files for '{query}':")
    for f in files:
        print(f"  {f.get('filepath', '')}")
        if f.get('purpose'):
            print(f"    → {f.get('purpose', '')[:60]}")
    
    return 0


def cmd_file_info(args):
    """Get info about a file."""
    filepath = args.filepath
    result = api_get(f"/files/{filepath}/info")
    
    if "error" in result:
        print(f"❌ Error: {result.get('error', 'Unknown')}")
        return 1
    
    f = result.get('file', {})
    print(f"\n📄 File: {f.get('filepath', '')}")
    print(f"   Purpose: {f.get('purpose', 'N/A')}")
    print(f"   Description: {f.get('description', 'N/A')}")
    patterns = json.loads(f.get('patterns', '[]'))
    print(f"   Patterns: {', '.join(patterns) if patterns else 'None'}")
    decisions = json.loads(f.get('decisions', '[]'))
    print(f"   Decisions: {', '.join(decisions) if decisions else 'None'}")
    print(f"   Updated: {f.get('updated_at', 'N/A')}")
    
    return 0


def cmd_file_context(args):
    """Get full context for a file (file + folder + related memories)."""
    filepath = args.filepath
    result = api_get(f"/file_context?path={filepath}")
    
    if "error" in result:
        print(f"❌ Error: {result.get('error', 'Unknown')}")
        return 1
    
    file_info = result.get('file')
    folder_info = result.get('folder')
    memories = result.get('related_memories', [])
    
    print(f"\n📋 Context for: {filepath}")
    print("="*50)
    
    if file_info:
        print(f"\n📄 FILE:")
        print(f"   Purpose: {file_info.get('purpose', 'N/A')}")
        print(f"   Description: {file_info.get('description', 'N/A')}")
        patterns = json.loads(file_info.get('patterns', '[]'))
        print(f"   Patterns: {', '.join(patterns) if patterns else 'None'}")
    
    if folder_info:
        print(f"\n📁 FOLDER: {folder_info.get('path', '')}")
        print(f"   Purpose: {folder_info.get('purpose', 'N/A')}")
        blockers = json.loads(folder_info.get('blockers', '[]'))
        if blockers:
            print(f"   Blockers: {', '.join(blockers)}")
    
    if memories:
        print(f"\n🧠 RELATED MEMORIES:")
        for m in memories[:3]:
            print(f"   - {m.get('text', '')[:80]}")
    
    print()
    return 0


